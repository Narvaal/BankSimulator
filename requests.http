### Health check
GET http://localhost:8080/health

### Login
POST http://localhost:8080/auth/login
Content-Type: application/json

{
  "email": "a@a.com",
  "password": "pass"
}

### Create Account
POST http://localhost:8080/accounts
Content-Type: application/json

{
  "name": "John Doe",
  "email": "a@a.com",
  "password": "pass"
}

### Purchase asset
POST http://localhost:8080/asset-listings/1/purchase
Content-Type: application/json
Authorization: Bearer MjoxNzY5ODkzMTgxOTQzOjE3Njk4OTY3ODE5NDM6OTg3MjBjZjUtYzdjYy00YzkzLWFjODktMTMzYTYzY2Y3MmU3.

{
  "buyerAccountId": 2
}

### Post assetOffer
POST http://localhost:8080/asset-offers
Content-Type: application/json

{
  "assetUnityId": 1,
  "price": 200.00,
  "token": "MToxNzY5ODkyNjgwOTA1OjE3Njk4OTYyODA5MDU6YzAwNzRhOTgtZDk3MS00OGQwLThlMDUtM2Y5YzgyMTE1Yjdi."
}

### Cancel assetOffer
POST http://localhost:8080/asset-offers/4/cancel
Content-Type: application/json

{
  "accountId": 5,
  "token": "MTA6MTc2OTgyODIyMTM3ODoxNzY5ODMxODIxMzc4OjkyYjA1YTFlLWVlODgtNDQ3NS1hYzg1LWNjOGNmNzBhMDQwNA==."
}

### Account Deposit
POST http://localhost:8080/accounts/2/deposit
Content-Type: application/json

{
  "amount": 500.00,
  "token": "MjoxNzY5ODkzMDUyNzA1OjE3Njk4OTY2NTI3MDU6M2YzYmY2MWQtYTgyMy00YmQ2LTgwODktNjA4YjBkYTlmYTE5."
}

### Give assetUnity
POST http://localhost:8080/assets/1/units
Content-Type: application/json

{
  "ownerAccountId": 1,
  "token": "MToxNzY5ODkyNjgwOTA1OjE3Njk4OTYyODA5MDU6YzAwNzRhOTgtZDk3MS00OGQwLThlMDUtM2Y5YzgyMTE1Yjdi."
}

### Create Asset bundle
POST http://localhost:8080/assets/bundles
Content-Type: application/json
X-Admin-Token: root

{
  "identifier": "weekly-pack-03",
  "assets": [
    { "text": "X: Rare", "totalSupply": 11 },
    { "text": "E: Epic", "totalSupply": 4 }
  ]
}

### Get Asset bundle
GET http://localhost:8080/assets/bundles

### Get Asset bundle itemns
GET http://localhost:8080/assets/bundles/1/items

### Generate Assets
POST http://localhost:8080/admin/assets/generate
X-Admin-Token: root

